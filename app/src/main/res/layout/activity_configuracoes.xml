<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Cabeçalho Fiserv -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fiserv SiTef"
            android:textColor="@color/primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configure as credenciais fornecidas pela Fiserv para integração com o servidor SiTef."
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="24dp"/>

        <!-- Empresa SiTef -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEmpresaId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Código da Empresa (empresaSitef)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="16dp"
            app:helperText="Código de 8 dígitos fornecido pela Fiserv"
            app:helperTextEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEmpresaId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:maxLength="8"
                android:fontFamily="monospace"
                android:textSize="16sp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- IP do Servidor SiTef -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilSitefIp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="IP do Servidor SiTef (enderecoSitef)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="16dp"
            app:helperText="Ex: 192.168.1.10  ou  tls.fiserv.com:443"
            app:helperTextEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSitefIp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri"
                android:fontFamily="monospace"
                android:textSize="16sp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- CNPJ -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilCnpj"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="CNPJ do Estabelecimento"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="16dp"
            app:helperText="14 dígitos, com ou sem pontuação"
            app:helperTextEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCnpj"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:maxLength="18"
                android:fontFamily="monospace"
                android:textSize="16sp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Divisor -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginVertical="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="JetinoPay API"
            android:textColor="@color/primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"
            android:layout_marginTop="8dp"/>

        <!-- URL da API -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilApiUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="URL da JetinoPay API"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="24dp"
            app:helperText="Ex: http://192.168.1.50:3000/"
            app:helperTextEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etApiUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri"
                android:fontFamily="monospace"
                android:textSize="14sp"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Status -->
        <TextView
            android:id="@+id/tvStatusConfig"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Não configurado"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:gravity="center"
            android:padding="12dp"
            android:background="#F5F5F5"
            android:layout_marginBottom="20dp"/>

        <!-- Botão salvar -->
        <Button
            android:id="@+id/btnSalvar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Salvar Configurações"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="@color/primary"
            android:layout_marginBottom="12dp"/>

        <!-- Botão testar conexão -->
        <Button
            android:id="@+id/btnTestarConexao"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Testar Conexão com Servidor SiTef"
            android:textSize="14sp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginBottom="12dp"/>

        <!-- Botão limpar -->
        <Button
            android:id="@+id/btnLimpar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Restaurar Padrões"
            android:textSize="14sp"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:textColor="@color/error"/>

    </LinearLayout>
</ScrollView>
