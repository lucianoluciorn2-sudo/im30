<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:padding="0dp">

    <!-- Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1565C0"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="JetinoPay — Teste MDB"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvModoTag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MODO TESTE"
            android:textColor="#FFEB3B"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@android:color/transparent" />
    </LinearLayout>

    <!-- Status MDB -->
    <LinearLayout
        android:id="@+id/cardStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical"
        android:elevation="2dp">

        <View
            android:id="@+id/viewStatusDot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/bg_dot_cinza" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:id="@+id/tvEstadoMdb"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inicializando..."
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#212121" />

            <TextView
                android:id="@+id/tvSubtituloMdb"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aguardando conexão MDB com Jetinno"
                android:textSize="11sp"
                android:textColor="#757575" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvSimulacao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SIM"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:background="#FF9800"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Área central — idle ou venda pendente -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Tela IDLE -->
        <LinearLayout
            android:id="@+id/layoutIdle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☕"
                android:textSize="64sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aguardando Jetinno..."
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#424242"
                android:textAlignment="center" />

            <TextView
                android:id="@+id/tvIdleSubtitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Conecte a cafeteira via MDB e selecione um produto"
                android:textSize="13sp"
                android:textColor="#9E9E9E"
                android:textAlignment="center"
                android:layout_marginTop="8dp" />

            <!-- Botão de simulação para testes sem hardware -->
            <Button
                android:id="@+id/btnSimular"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Simular Produto Selecionado"
                android:textColor="#1565C0"
                android:background="@android:color/transparent"
                android:paddingTop="24dp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Valor simulado: R$ "
                    android:textSize="13sp"
                    android:textColor="#616161" />

                <EditText
                    android:id="@+id/etValorSimulado"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="5.50"
                    android:inputType="numberDecimal"
                    android:textSize="13sp"
                    android:textColor="#212121" />
            </LinearLayout>
        </LinearLayout>

        <!-- Tela VENDA PENDENTE -->
        <LinearLayout
            android:id="@+id/layoutVenda"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Produto selecionado na Jetinno"
                android:textSize="14sp"
                android:textColor="#757575"
                android:textAlignment="center" />

            <TextView
                android:id="@+id/tvValorVenda"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R$ 0,00"
                android:textSize="52sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:textAlignment="center"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvItemVenda"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Item #1"
                android:textSize="13sp"
                android:textColor="#9E9E9E"
                android:textAlignment="center"
                android:layout_marginBottom="40dp" />

            <!-- Botões APROVAR / NEGAR -->
            <Button
                android:id="@+id/btnAprovar"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="✓  APROVAR — Liberar Produto"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#2E7D32"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnNegar"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="✗  NEGAR — Recusar Venda"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:backgroundTint="#C62828" />
        </LinearLayout>

        <!-- Tela RESULTADO -->
        <LinearLayout
            android:id="@+id/layoutResultado"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvResultadoIcone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓"
                android:textSize="72sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvResultadoTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="APROVADO"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:textAlignment="center" />

            <TextView
                android:id="@+id/tvResultadoValor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R$ 5,50"
                android:textSize="24sp"
                android:textColor="#424242"
                android:textAlignment="center"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp" />

            <Button
                android:id="@+id/btnNovaVenda"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Nova Transação"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1565C0" />
        </LinearLayout>

    </FrameLayout>

    <!-- Log de eventos MDB -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:orientation="vertical"
        android:background="#212121">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LOG MDB"
            android:textColor="#757575"
            android:textSize="10sp"
            android:paddingStart="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="4dp"
            android:letterSpacing="0.1" />

        <ScrollView
            android:id="@+id/scrollLog"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#B0BEC5"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp" />
        </ScrollView>
    </LinearLayout>

</LinearLayout>
